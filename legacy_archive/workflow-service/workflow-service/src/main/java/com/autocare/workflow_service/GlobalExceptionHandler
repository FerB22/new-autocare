package com.autocare.workflow_service;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.validation.FieldError;
import org.springframework.web.bind.MethodArgumentNotValidException;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.bind.annotation.RestControllerAdvice;

import java.util.HashMap;
import java.util.Map;

/**
 * Interceptor global de excepciones para el microservicio de Flujo de Trabajo.
 * @RestControllerAdvice es una anotación basada en Programación Orientada a Aspectos (AOP).
 * Actúa como un "escudo" centralizado que captura las excepciones lanzadas por cualquier
 * controlador dentro de este microservicio antes de que la respuesta llegue al cliente.
 * Su objetivo es estandarizar el formato de los errores (devolviendo siempre un JSON limpio)
 * y evitar tener bloques try-catch repetitivos en los endpoints.
 */
@RestControllerAdvice
public class GlobalExceptionHandler {

    // Captura errores de @Valid (campos inválidos)
    /**
     * Intercepta las excepciones de validación de Jakarta Bean Validation.
     * Este método se dispara automáticamente cuando una petición (como un POST para crear 
     * una OrdenTrabajo) no cumple con las reglas del modelo (ej. prioridad en blanco o sin idVehiculo).
     * * @param ex La excepción que agrupa todos los campos que fallaron la validación.
     * @return Un mapa clave-valor serializado a JSON. Ejemplo: {"prioridad": "La prioridad es obligatoria"}.
     * Es ideal para el frontend, ya que permite iterar sobre las llaves del JSON y pintar
     * el error exactamente debajo del input correspondiente en la interfaz.
     */
    @ExceptionHandler(MethodArgumentNotValidException.class)
    public ResponseEntity<Map<String, String>> handleValidationErrors(
            MethodArgumentNotValidException ex) {

        // Usamos un HashMap para construir dinámicamente la lista de errores.
        Map<String, String> errores = new HashMap<>();
        for (FieldError error : ex.getBindingResult().getFieldErrors()) {
            errores.put(error.getField(), error.getDefaultMessage());
        }
        
        // Retorna HTTP 400 (Bad Request) indicando que el cliente envió datos mal formados.
        return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(errores);
    }

    // Captura errores generales de lógica (RuntimeException)
    /**
     * Red de seguridad para capturar errores de reglas de negocio.
     * Atrapa todas las RuntimeException lanzadas intencionalmente desde la capa 
     * OrdenTrabajoService (por ejemplo: "El mecánico no está disponible" o "Transición de estado inválida").
     * * @param ex La excepción en tiempo de ejecución con el mensaje de negocio.
     * @return Un JSON estructurado con la forma {"error": "Detalle del problema"}.
     * Esto oculta la traza técnica (stacktrace) de Java, protegiendo la seguridad de la 
     * aplicación y entregando un mensaje legible para el usuario final.
     */
    @ExceptionHandler(RuntimeException.class)
    public ResponseEntity<Map<String, String>> handleRuntimeException(
            RuntimeException ex) {

        // Map.of() crea de forma rápida y concisa un mapa inmutable con un solo par clave-valor.
        // Se devuelve HTTP 400 (Bad Request) porque la operación, aunque bien formada 
        // sintácticamente, fue rechazada por la lógica interna del negocio.
        return ResponseEntity.status(HttpStatus.BAD_REQUEST)
                .body(Map.of("error", ex.getMessage()));
    }
}